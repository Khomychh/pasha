# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-3.5-flash-lite

# Password guests type in on the login page
GUEST_PASSWORD=

# Password for the /admin persona editor (must differ from GUEST_PASSWORD)
ADMIN_PASSWORD=

# Random long string used to sign session cookies. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional rate-limit tuning (defaults shown)
# RATE_LIMIT_MAX_MESSAGES=60
# RATE_LIMIT_WINDOW_SECONDS=3600
# RATE_LIMIT_MIN_INTERVAL_SECONDS=1.5

# Domain Caddy will serve and obtain a TLS certificate for (production deploy only)
DOMAIN=
